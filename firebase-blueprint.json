{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item in the bakery price list",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the pastry" },
        "price": { "type": "number", "description": "Price in Euros" },
        "category": { "type": "string", "description": "Category like Cake, Muffin, etc." },
        "imageUrl": { "type": "string", "description": "URL to the pastry image" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name", "price", "category"]
    },
    "BakerySettings": {
      "title": "Bakery Settings",
      "description": "Global settings for the bakery",
      "type": "object",
      "properties": {
        "cakeOfTheDay": { "type": "string", "description": "The special cake of the day" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["cakeOfTheDay"]
    }
  },
  "firestore": {
    "menu_items": {
      "schema": "MenuItem",
      "description": "Collection of products offered by the bakery"
    },
    "settings": {
      "schema": "BakerySettings",
      "description": "Single document for global bakery configuration"
    }
  }
}
